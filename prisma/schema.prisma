generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  // url      = env("DIRECT_URL")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model WebhookEmail {
  id        String   @id @default(cuid())
  from      String?
  to        String?
  subject   String?
  text      String?  @db.Text
  html      String?  @db.Text
  rawData   Json?
  createdAt DateTime @default(now())
}

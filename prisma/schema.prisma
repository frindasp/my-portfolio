generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String    @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime  @default(now())
  Messages  Message[]
}

model WebhookEmail {
  id        String   @id @default(cuid())
  from      String?
  to        String?
  subject   String?
  text      String?  @db.Text
  html      String?  @db.Text
  rawData   Json?
  createdAt DateTime @default(now())
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  Users User[]
}

model User {
  id                  String                @id @default(cuid())
  name                String?
  email               String
  password            String
  roleId              String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  twoFactorEnabled    Boolean               @default(false)
  mfaDismissedAt      DateTime?
  authenticators      Authenticator[]
  HistoryActivityUser HistoryActivityUser[]
  Messages            Message[]
  totp                TotpAuthenticator[]
  Role                Role                  @relation(fields: [roleId], references: [id])

  @@unique([email, roleId])
  @@index([roleId], map: "User_roleId_fkey")
}

model TotpAuthenticator {
  id            String   @id @default(cuid())
  userId        String
  secret        String
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  name          String   @default("Authenticator")
  setupComplete Boolean  @default(false)
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Authenticator {
  id                   String  @id @default(cuid())
  credentialID         String  @unique
  userId               String
  publicKey            Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  enabled              Boolean @default(true)
  User                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id             String        @id @default(cuid())
  content        String        @db.Text
  senderId       String?
  createdAt      DateTime      @default(now())
  contactId      String?
  isAdmin        Boolean       @default(false)
  senderEmail    String?
  conversationId String?
  isRead         Boolean       @default(false)
  Contact        Contact?      @relation(fields: [contactId], references: [id])
  Conversation   Conversation? @relation(fields: [conversationId], references: [id])
  User           User?         @relation(fields: [senderId], references: [id])

  @@index([contactId], map: "Message_contactId_fkey")
  @@index([senderId], map: "Message_senderId_fkey")
  @@index([conversationId], map: "Message_conversationId_fkey")
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model HistoryActivityUser {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  description String?  @db.Text
  route       String?
  method      String?
  ipAddress   String?
  deviceType  String?
  userAgent   String?
  location    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  User        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model Conversation {
  id         String    @id @default(cuid())
  email      String
  name       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  roleId     String?
  title      String?
  adminAlias String?
  userAlias  String?
  Message    Message[]
}

model ConversationReadState {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  isRead         Boolean  @default(true)
  isArchived     Boolean  @default(false)
  isFavorite     Boolean  @default(false)
  isMuted        Boolean  @default(false)
  isPinned       Boolean  @default(false)

  @@unique([conversationId, userId])
}
